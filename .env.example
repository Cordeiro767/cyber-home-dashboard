# Cyber Home Dashboard local configuration

# Auto-scan interval in seconds. Minimum enforced by backend: 10.
SCAN_INTERVAL_SECONDS=60

# Allowed local network for inventory scans.
# Run: py -3 .\detect_local_network.py
ALLOWED_NETWORK=192.168.1.0/24

# Optional Nmap usage. Keep false for a lighter portfolio/demo setup.
USE_NMAP=false

# False uses hosts visible in ARP table. True enables a ping sweep inside ALLOWED_NETWORK.
FALLBACK_SWEEP=false

# Optional gateway override if Windows route detection fails.
# GATEWAY_IP=192.168.1.1
